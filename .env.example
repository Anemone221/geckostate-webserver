# ============================================================
# COPY THIS FILE TO backend/.env AND FILL IN YOUR VALUES
# Never commit the actual .env file — it contains secrets
# ============================================================

# --- MongoDB ---
# When running via Docker Compose, "mongo" is the hostname (the service name above)
# When running locally outside Docker, use "localhost"
# The authenticated URI includes the username/password set in docker-compose.yml.
MONGO_URI=
# Password for the MongoDB root user (used by docker-compose.yml)
MONGO_PASSWORD=change_me_to_a_strong_password

# --- Server ---
PORT=3000
# Frontend URL for CORS — only this origin can call the API.
# In development, Vite runs on port 5173. In production, set to your actual domain.
FRONTEND_URL=http://localhost:5173

# Session secret — change this to any long random string before deploying
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# --- CCP SSO ---
# Register your application at: https://developers.eveonline.com/
# Set the callback URL in your app registration to match CCP_CALLBACK_URL below
CCP_CLIENT_ID=
CCP_CLIENT_SECRET=
CCP_CALLBACK_URL=http://localhost:3000/api/auth/callback

# --- ESI ---
# Your contact email goes in the User-Agent so CCP can reach you if your app misbehaves
ESI_USER_AGENT=geckostate-market-planner/1.0 (your@email.com)

# --- Data Sources ---
EVEREF_BASE_URL=https://data.everef.net
CCP_SDE_URL=https://developers.eveonline.com/static-data/eve-online-static-data-latest-jsonl.zip

# Optional: path to an already-extracted SDE folder on disk.
# When set, the SDE import reads from local files and skips downloading the zip.
# Leave empty (or omit) to always download from CCP.
# Example: LOCAL_SDE_PATH=F:/Downloads/eve-online-static-data-3231590-jsonl
LOCAL_SDE_PATH=

# --- EVE Market Region ---
# 10000002 = The Forge (Jita) — the main trading hub
PRIMARY_REGION_ID=10000002
