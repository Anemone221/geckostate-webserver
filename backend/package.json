{
  "name": "geckostate-backend",
  "version": "1.0.0",
  "description": "EVE Online market planning tool — backend API",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "import:sde": "tsx src/scripts/import-sde.ts",
