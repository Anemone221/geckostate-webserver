    "unbzip2-stream": "^1.4.3",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/unzipper": "^0.10.10",
    "@vitest/coverage-v8": "^4.0.18",
